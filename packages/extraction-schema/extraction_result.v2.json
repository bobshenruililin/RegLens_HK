{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reglens.hk/schemas/extraction_result.v2.json",
  "title": "RegLensHKExtractionResultV2",
  "description": "Strict extraction output v2. Providers emit client_ref only; application assigns persistent IDs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "document_sha256",
    "extractor",
    "decision_metadata",
    "propositions",
    "coverage"
  ],
  "properties": {
    "schema_version": { "const": "2.0.0" },
    "document_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "extractor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pipeline_version",
        "model_provider",
        "model_version",
        "prompt_version"
      ],
      "properties": {
        "pipeline_version": { "type": "string", "minLength": 1 },
        "model_provider": { "type": "string", "minLength": 1 },
        "model_version": { "type": "string", "minLength": 1 },
        "prompt_version": { "type": "string", "minLength": 1 }
      }
    },
    "decision_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["regulator_code", "profession", "case_refs", "dates"],
      "properties": {
        "regulator_code": { "enum": ["MCHK", "DCHK"] },
        "profession": { "enum": ["doctor", "dentist"] },
        "case_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "dates": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "inquiry": { "type": ["string", "null"], "format": "date" },
            "judgment": { "type": ["string", "null"], "format": "date" },
            "publication": { "type": ["string", "null"], "format": "date" },
            "conduct": { "type": ["string", "null"], "format": "date" },
            "order_effective": { "type": ["string", "null"], "format": "date" }
          }
        },
        "defendant_registration_no": { "type": ["string", "null"] },
        "defendant_name_as_published": { "type": ["string", "null"] }
      }
    },
    "propositions": {
      "type": "array",
      "items": { "$ref": "#/$defs/proposition" }
    },
    "relations": {
      "type": "array",
      "default": [],
      "items": { "$ref": "#/$defs/relation" }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["missing_fields", "warnings"],
      "properties": {
        "missing_fields": {
          "type": "array",
          "items": { "type": "string" }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "proposition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "client_ref",
        "prop_type",
        "epistemic_class",
        "derivation",
        "claim_text",
        "confidence",
        "evidence"
      ],
      "properties": {
        "client_ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z][a-z0-9_\\-]{0,127}$"
        },
        "prop_type": {
          "enum": [
            "charge",
            "rule",
            "finding",
            "legal_test",
            "aggravating_factor",
            "mitigating_factor",
            "sanction",
            "costs",
            "authority",
            "appeal_status"
          ]
        },
        "epistemic_class": { "enum": ["fact", "interpretation"] },
        "derivation": { "enum": ["verbatim", "normalized", "inferred"] },
        "claim_text": { "type": "string", "minLength": 1, "maxLength": 4000 },
        "structured": { "type": ["object", "null"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "prop_type": { "const": "legal_test" } },
            "required": ["prop_type"]
          },
          "then": {
            "properties": { "epistemic_class": { "const": "interpretation" } }
          }
        }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["page_no", "quote"],
      "properties": {
        "span_id": { "type": ["string", "null"] },
        "page_no": { "type": "integer", "minimum": 1 },
        "quote": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "char_start": { "type": ["integer", "null"], "minimum": 0 },
        "char_end": { "type": ["integer", "null"], "minimum": 0 }
      },
      "dependentRequired": {
        "char_start": ["char_end"],
        "char_end": ["char_start"]
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relation_type", "from_ref", "to_ref"],
      "properties": {
        "relation_type": {
          "enum": [
            "finding_resolves_charge",
            "sanction_applies_to_charge",
            "rule_governs_charge",
            "authority_supports_legal_test",
            "factor_affects_sanction"
          ]
        },
        "from_ref": { "type": "string", "minLength": 1 },
        "to_ref": { "type": "string", "minLength": 1 }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reglens.hk/schemas/source_automation_policy.v1.json",
  "title": "Source automation policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policies"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "regulator_code",
          "official_hosts",
          "allowed_path_prefixes",
          "official_index_urls",
          "adapter_id",
          "adapter_version",
          "enabled",
          "discovery_mode",
          "content_use_posture",
          "public_visibility_policy_ref",
          "min_delay_seconds",
          "max_concurrency",
          "max_requests_per_run",
          "max_document_bytes",
          "allowed_mime_types",
          "redirect_policy",
          "attribution",
          "require_user_agent_contact"
        ],
        "properties": {
          "source_id": { "type": "string", "minLength": 1 },
          "regulator_code": { "type": "string", "enum": ["MCHK", "DCHK"] },
          "official_hosts": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "allowed_path_prefixes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "official_index_urls": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "format": "uri" }
          },
          "adapter_id": { "type": "string", "minLength": 1 },
          "adapter_version": { "type": "string", "minLength": 1 },
          "enabled": { "type": "boolean" },
          "discovery_mode": {
            "type": "string",
            "enum": ["disabled", "metadata_only", "acquire_documents"]
          },
          "document_acquisition": {
            "type": "string",
            "enum": ["disabled", "manual_only", "policy_controlled"],
            "default": "disabled"
          },
          "content_use_posture": {
            "type": "string",
            "enum": [
              "internal_non_commercial_research",
              "metadata_discovery_only",
              "blocked"
            ]
          },
          "public_visibility_policy_ref": { "type": "string", "minLength": 1 },
          "terms_url": { "type": ["string", "null"], "format": "uri" },
          "terms_snapshot_date": { "type": ["string", "null"], "format": "date" },
          "robots_url": { "type": ["string", "null"], "format": "uri" },
          "last_robots_result": {
            "type": "string",
            "enum": ["allow", "partial", "disallow", "unavailable", "unchecked"]
          },
          "robots_checked_at": { "type": ["string", "null"], "format": "date-time" },
          "operator_approval_ref": { "type": ["string", "null"] },
          "min_delay_seconds": { "type": "number", "minimum": 2 },
          "max_concurrency": { "type": "integer", "minimum": 1, "maximum": 1 },
          "max_requests_per_run": { "type": "integer", "minimum": 1 },
          "max_document_bytes": { "type": "integer", "minimum": 1 },
          "allowed_mime_types": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "redirect_policy": {
            "type": "string",
            "enum": ["same_host_allowlist", "deny"]
          },
          "attribution": { "type": "string", "minLength": 1 },
          "require_user_agent_contact": { "type": "boolean" },
          "publication_caveats": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
